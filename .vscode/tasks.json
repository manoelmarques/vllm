{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "docker-build",
			"label": "docker-build",
			"platform": "python",
			"dockerBuild": {
				"tag": "vllm-cpu-env:latest",
				"dockerfile": "${workspaceFolder}/Dockerfile.arm",
				"context": "${workspaceFolder}",
				"pull": true
			}
		},
		{
			"type": "docker-run",
			"label": "docker-run: debug",
			"dependsOn": [
				"docker-build"
			],
			"python": {
				"module": "vllm.entrypoints.openai.api_server",
				"args": ["--model","Qwen/Qwen2.5-0.5B-Instruct", "--dtype","float16"],
				"debugPort": 5678,
				"wait": true
			}
		}
	]
}